# Copy this file to .env(.local) and fill in the values.

# --- SMTP (Nodemailer) ---
# Used by app/api/contact/route.ts to send the contact form email.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Inbox that receives the admin notification for every contact form submission.
CONTACT_ADMIN_EMAIL=

# --- Google reCAPTCHA v3 ---
# https://www.google.com/recaptcha/admin
# Public site key, exposed to the browser (must be prefixed with NEXT_PUBLIC_).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key, server-side only, used to verify tokens in the API route.
RECAPTCHA_SECRET_KEY=
